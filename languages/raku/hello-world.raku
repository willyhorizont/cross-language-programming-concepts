use v6.d;

put "hello, world";
print "hello, world\n";
say "hello, world";
"hello, world".put;
"hello, world\n".print;
"hello, world".say;
"hello, world".put();
"hello, world\n".print();
"hello, world".say();
put("hello, world");
print("hello, world\n");
say("hello, world");
"hello, world" ==> put();
"hello, world\n" ==> print();
"hello, world" ==> say();
